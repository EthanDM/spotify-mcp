{
  "name": "spotify-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth": "tsx src/auth/cli.ts",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings=0",
    "personalize:refresh": "tsx src/personalization/cli.ts refresh",
    "data:migrate": "tsx src/data/migrate.ts",
    "data:resolve": "tsx src/data/resolve.ts",
    "smoke": "tsx src/smoke.ts",
    "skills:check": "node scripts/check-skill-privacy.mjs",
    "skills:install": "node scripts/install-skills.mjs",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.6.0",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^3.2.4"
  }
}
