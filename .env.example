SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8787/callback

# Optional local runtime root. Authentication always remains here.
# SPOTIFY_MCP_DATA_DIR=~/.config/spotify-mcp

# Optional shared durable-state root. Set a unique machine id on every Mac.
# SPOTIFY_MCP_SHARED_DATA_DIR=~/Library/Mobile Documents/com~apple~CloudDocs/App Data/spotify-mcp
# SPOTIFY_MCP_MACHINE_ID=desktop
